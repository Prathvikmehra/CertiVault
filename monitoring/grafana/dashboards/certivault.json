      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "certivault-prometheus" },
          "expr": "sum(rate(certivault_http_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(certivault_http_requests_total[5m])) * 100",
          "legendFormat": "error rate %",
          "refId": "A"
