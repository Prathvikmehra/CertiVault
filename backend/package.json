{
  "name": "certivault-backend",
  "version": "0.1.0",
  "private": true,
  "description": "CertiVault REST API",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "test": "node --test",
    "format:check": "prettier --check \"src/**/*.js\" \"tests/**/*.js\" \"*.json\"",
    "format": "prettier --write \"src/**/*.js\" \"tests/**/*.js\" \"*.json\""
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "multer": "^2.0.2"
  },
  "devDependencies": {
    "prettier": "^3.9.4"
  }
}
