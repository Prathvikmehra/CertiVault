{
  "name": "certivault-backend",
  "version": "1.0.0",
  "private": true,
  "description": "CertiVault REST API - Smart Document Management & Verification Platform",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" \"*.json\"",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"*.json\"",
    "test": "cross-env NODE_ENV=test tsx --test tests/unit/env.test.js tests/unit/gracefulShutdown.test.js tests/integration/app.test.ts",
    "test:watch": "cross-env NODE_ENV=test tsx --watch --test tests/unit/env.test.js tests/unit/gracefulShutdown.test.js tests/integration/app.test.ts",
    "test:coverage": "cross-env NODE_ENV=test c8 tsx --test tests/unit/env.test.js tests/unit/gracefulShutdown.test.js tests/integration/app.test.ts",
    "test:integration": "cross-env NODE_ENV=test tsx --test tests/integration/app.test.ts",
    "test:unit": "cross-env NODE_ENV=test tsx --test tests/unit/env.test.js tests/unit/gracefulShutdown.test.js",
    "seed": "tsx src/scripts/seed-admin.ts",
    "migrate": "tsx src/scripts/run-migrations.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1085.0",
    "@aws-sdk/s3-request-presigner": "^3.1085.0",
    "@bull-board/api": "^8.1.2",
    "@bull-board/express": "^8.1.2",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.80.2",
    "cloudinary": "^2.10.0",
    "compression": "^1.7.5",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "dotenv": "^17.4.2",
    "express": "^5.0.1",
    "express-fileupload": "^1.5.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.2.1",
    "helmet": "^8.3.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^9.7.4",
    "mongoose-paginate-v2": "^1.8.5",
    "morgan": "^1.10.0",
    "multer": "^2.2.0",
    "nanoid": "^6.0.0",
    "nodemailer": "^9.0.3",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "qrcode": "^1.5.4",
    "prom-client": "^15.1.3",
    "redis": "^6.1.0",
    "resend": "^6.17.2",
    "sharp": "^0.35.3",
    "speakeasy": "^2.0.0",
    "ua-parser-js": "^2.0.0",
    "uuid": "^14.0.1",
    "validator": "^13.12.0",
    "winston": "^3.17.0",
    "xss-clean": "^0.1.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/hpp": "^0.2.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.2.0",
    "@types/node": "^26.1.1",
    "@types/nodemailer": "^6.4.17",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.16",
    "@types/passport-jwt": "^4.0.1",
    "@types/qrcode": "^1.5.6",
    "@types/speakeasy": "^2.0.10",
    "@types/supertest": "^7.2.0",
    "@types/ua-parser-js": "^0.7.39",
    "@types/uuid": "^10.0.0",
    "@types/validator": "^13.12.2",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.10",
    "cross-env": "^10.1.0",
    "eslint": "^10.7.0",
    "mongodb-memory-server": "^11.2.0",
    "prettier": "^3.9.5",
    "supertest": "^7.0.0",
    "tsx": "^4.23.1",
    "typescript": "^5.8.3",
    "vitest": "^4.1.10"
  }
}
