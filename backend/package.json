{
  "name": "certivault-backend",
  "version": "0.1.0",
  "private": true,
  "description": "CertiVault REST API",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "test": "node --test",
    "format:check": "prettier --check \"src/**/*.js\" \"tests/**/*.js\" \"*.json\"",
    "format": "prettier --write \"src/**/*.js\" \"tests/**/*.js\" \"*.json\""
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1085.0",
    "@aws-sdk/s3-request-presigner": "^3.1085.0",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "express-validator": "^7.3.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.7.4",
    "multer": "^2.0.2"
  },
  "devDependencies": {
    "prettier": "^3.9.4"
  }
}
