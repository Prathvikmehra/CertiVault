{
  "name": "certivault-backend",
  "version": "1.0.0",
  "private": true,
  "description": "CertiVault REST API - Smart Document Management & Verification Platform",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" \"*.json\"",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"*.json\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run tests/integration",
    "test:unit": "vitest run tests/unit",
    "seed": "tsx src/scripts/seed-admin.ts",
    "migrate": "tsx src/scripts/run-migrations.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "express": "^5.0.1",
    "cors": "^2.8.5",
    "helmet": "^8.0.0",
    "mongoose": "^8.9.5",
    "mongoose-paginate-v2": "^1.8.5",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.24.1",
    "multer": "^1.4.5-lts.1",
    "uuid": "^11.0.5",
    "redis": "^4.7.0",
    "nodemailer": "^6.9.16",
    "winston": "^3.17.0",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.2.1",
    "cookie-parser": "^1.4.7",
    "compression": "^1.7.5",
    "hpp": "^0.2.3",
    "xss-clean": "^0.1.4",
    "express-mongo-sanitize": "^2.2.0",
    "@aws-sdk/client-s3": "^3.726.0",
    "@aws-sdk/s3-request-presigner": "^3.726.0",
    "sharp": "^0.33.5",
    "qrcode": "^1.5.4",
    "crypto-js": "^4.2.0",
    "nanoid": "^5.0.9",
    "bullmq": "^5.34.8",
    "ioredis": "^5.4.2",
    "dotenv": "^16.4.7",
    "morgan": "^1.10.0",
    "express-fileupload": "^1.5.1",
    "ua-parser-js": "^2.0.0",
    "validator": "^13.12.0",
    "speakeasy": "^2.0.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/cors": "^2.8.17",
    "@types/node": "^22.10.7",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/uuid": "^10.0.0",
    "@types/nodemailer": "^6.4.17",
    "@types/cookie-parser": "^1.4.8",
    "@types/compression": "^1.7.5",
    "@types/hpp": "^0.2.6",
    "@types/morgan": "^1.9.9",
    "@types/ua-parser-js": "^0.7.39",
    "@types/validator": "^13.12.2",
    "@types/speakeasy": "^2.0.10",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.16",
    "@types/passport-jwt": "^4.0.1",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.3",
    "@vitest/coverage-v8": "^3.0.3",
    "mongodb-memory-server": "^10.1.3",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.2"
  }
}