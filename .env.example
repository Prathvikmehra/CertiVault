# =============================================================================
# CertiVault Environment Variables — Docker Compose & Production
# =============================================================================
# Copy to .env and populate with your actual values.
# Never commit .env to version control.
# =============================================================================

# ─── General ──────────────────────────────────────────────────────────────────
NODE_ENV=production

# ─── Grafana ───────────────────────────────────────────────────────────────────
# Used in docker-compose.prod.yml for the Grafana admin password
GF_ADMIN_PASSWORD=your_secure_password_here

# ─── Backend ──────────────────────────────────────────────────────────────────
# These are loaded by ./backend/.env, which is mounted via env_file in compose
# Reference ./backend/.env.example for required backend vars

# ─── Frontend ──────────────────────────────────────────────────────────────────
# These are loaded by ./frontend/.env, which is mounted via env_file in compose
# Reference ./frontend/.env.example for required frontend vars
